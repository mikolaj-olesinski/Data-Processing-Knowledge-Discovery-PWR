{
  "title": "Lab7 — Web Summarizer",
  "uid": "lab7-main",
  "tags": ["lab7"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Czas odpowiedzi LLM — p50 / p95 [s]",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineWidth": 2}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le) (rate(lab7_llm_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(lab7_llm_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Cache — trafienia/pudła (rate/min) wg warstwy",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60, "stacking": {"mode": "normal"}}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (layer, result) (rate(lab7_cache_events_total[5m])) * 60",
          "legendFormat": "{{layer}} / {{result}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Błędy pipeline'u (rate/min) wg typu",
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 20}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (rate(lab7_errors_total[5m])) * 60",
          "legendFormat": "{{kind}}"
        }
      ]
    }
  ]
}
